<Window x:Class="AutoLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AutoLauncher"
        Height="360" Width="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Opacity="0"
        FontFamily="Segoe UI"
        FontSize="13"
        Foreground="{DynamicResource Text}"
        SnapsToDevicePixels="True"
        MouseDown="Window_MouseDown"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <!-- Main container: provides dark background + shadow, transparent window lets the background through -->
    <Border x:Name="RootContainer"
            Margin="25"
            Background="{DynamicResource Base}">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="6"
                              Color="#000000"
                              BlurRadius="18"
                              Opacity="0.6" />
        </Border.Effect>
        <Grid Margin="15,10,15,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Pink}"
                       Text="🐾  Launching programs, meow!  🐾"
                       Margin="0,0,0,10" />

            <!-- Cat GIF (GifAnimator) -->
            <Border Grid.Row="1"
                    Width="150" Height="150"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    CornerRadius="12"
                    ClipToBounds="True">
                <Image x:Name="CatImage"
                       Width="150" Height="150"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True" />
            </Border>

            <!-- Current action: icon + bold text -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0">
                <Image x:Name="AppIconImage"
                       Width="16" Height="16"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
                <TextBlock x:Name="ActionText"
                           Foreground="{DynamicResource Blue}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Text="" />
            </StackPanel>

            <!-- Progress bar with glow & rounded corners -->
            <Grid x:Name="ProgressBarGrid"
                  Grid.Row="3"
                  Height="10"
                  Margin="10,10,10,0">
                <Grid.Effect>
                    <DropShadowEffect x:Name="ProgressGlow"
                                      ShadowDepth="0"
                                      BlurRadius="10"
                                      Opacity="0.4" />
                </Grid.Effect>
                <!-- Track (background) -->
                <Rectangle x:Name="ProgressTrack"
                           Fill="{DynamicResource Surface0}"
                           RadiusX="5" RadiusY="5" />
                <!-- Indicator (foreground fill) -->
                <Rectangle x:Name="ProgressIndicator"
                           HorizontalAlignment="Left"
                           Width="0"
                           Fill="{DynamicResource Pink}"
                           RadiusX="5" RadiusY="5" />
            </Grid>

            <!-- Counter (hidden initially) -->
            <TextBlock Grid.Row="4"
                       x:Name="ProgressText"
                       Foreground="{DynamicResource Subtext0}"
                       FontSize="12"
                       Visibility="Collapsed"
                       Margin="0,6,0,0" />
        </Grid>
    </Border>
</Window>